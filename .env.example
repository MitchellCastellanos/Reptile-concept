# Postgres connection string (Neon, Vercel Postgres, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Random secret used to sign the admin session cookie (and review links).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me"

# Optional — transactional emails are logged to the console until this is set.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Reptile Concept <ventes@reptileconcept.ca>"

# Optional — public site URL used in email links (admin order link, review link).
# Defaults to VERCEL_URL in production, http://localhost:3000 otherwise.
# NEXT_PUBLIC_SITE_URL="https://reptileconcept.ca"

# Optional — protects GET /api/cron/expire-orders if it's reachable publicly.
# CRON_SECRET="change-me-too"
